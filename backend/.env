# cadena de conexión Mongo; cuando se ejecute con docker-compose
# el servicio se llama "mongo" y la url debe apuntar a él:
# MONGO_URI=mongodb://mongo:27017/desarrollo2
# de lo contrario, usa localhost si arrancas Mongo externamente.
MONGO_URI=mongodb://localhost:27017/desarrollo2

